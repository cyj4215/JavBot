TELEGRAM_BOT_TOKEN=your_bot_token_here

# 可选：网络代理，例如 http://host.docker.internal:7890
HTTP_PROXY=

# MySQL 数据库配置
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=javbot
MYSQL_PASSWORD=javbot
MYSQL_DATABASE=javbot

# 可选：返回数量限制
LATEST_LIMIT=5
TOP_LIMIT=5
SEND_LATEST_COVERS=1
LATEST_COVER_LIMIT=3
MAGNET_LIMIT=5
MAGNET_TIMEOUT=20
RANK_LIMIT_DEFAULT=20
RANK_PAGE_DEFAULT=1
RANK_FEATURE_AVATARS=0
RANK_AVATAR_LIMIT=3
RANK_CACHE_TTL=900
PROFILE_CACHE_TTL=1800

# 仅允许这些 Telegram 用户使用，逗号分隔；留空则不限制
ALLOWED_USER_IDS=

# 可选：默认界面语言 (zh_CN / en_US / ja_JP)
I18N_DEFAULT_LANGUAGE=zh_CN

# 可选：日志等级 DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO

# 可选：是否查询无码内容，1=开启，0=关闭
UNCENSORED=0

# 可选：管理员用户ID，用于接收启动消息
ADMIN_USER_ID=

# 可选：新作品推送功能
# 全局是否开启推送功能，1=开启，0=关闭
PUSH_ENABLED=1
# 推送检查间隔（秒），默认3600秒（1小时）
PUSH_CHECK_INTERVAL=3600
